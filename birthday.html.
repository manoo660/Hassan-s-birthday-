<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Abubakar! 🎉</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght=700&family=Poppins:wght=300;400;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --pink: #ffb7b2;
            --blue: #b5ead7;
            --white: rgba(255, 255, 255, 0.8);
            --gold: #ffdab9;
            --text-dark: #4a4a4a;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(-45deg, #ffb7b2, #e2f0cb, #b5ead7, #ffdac1);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            overflow-x: hidden;
            color: var(--text-dark);
            text-align: center;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Fairy Lights */
        .fairy-lights {
            display: flex;
            justify-content: space-around;
            width: 100%;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 10;
            list-style: none;
            padding: 0;
        }

        .fairy-lights li {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            animation: flash 1.5s infinite alternate;
        }

        .fairy-lights li:nth-child(odd) { background: #fff; box-shadow: 0 0 10px #fff, 0 0 20px #ffb7b2; }
        .fairy-lights li:nth-child(even) { background: #ffd700; box-shadow: 0 0 10px #ffd700, 0 0 20px #ffdab9; }

        @keyframes flash {
            0% { opacity: 0.4; }
            100% { opacity: 1; }
        }

        /* Container & Glassmorphism */
        .container {
            max-width: 800px;
            margin: 50px auto;
            padding: 40px 20px;
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
            position: relative;
            z-index: 2;
        }

        /* Typography & Typing Animation */
        h1 {
            font-family: 'Dancing Script', cursive;
            font-size: 3.5rem;
            color: #5d5d5d;
            margin-bottom: 20px;
            opacity: 0;
            animation: fadeIn 2s ease-in forwards;
        }

        .typing-text {
            font-size: 1.5rem;
            border-right: 3px solid #5d5d5d;
            white-space: nowrap;
            overflow: hidden;
            margin: 0 auto 30px auto;
            width: fit-content;
            animation: typing 3.5s steps(30, end), blink .75s step-end infinite;
        }

        @keyframes fadeIn { to { opacity: 1; } }
        @keyframes typing { from { width: 0 } to { width: 100% } }
        @keyframes blink { from, to { border-color: transparent } 50% { border-color: #5d5d5d; } }

        /* Bubu Dudu Illustrations (SVG - No Image Files Used) */
        .bubu-dudu-box {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 30px 0;
        }

        .panda-art {
            width: 100px;
            height: 100px;
            animation: bounce 2s infinite alternate;
        }

        @keyframes bounce {
            0% { transform: translateY(0); }
            100% { transform: translateY(-15px); }
        }

        /* Birthday Cake */
        .cake-container {
            margin: 40px 0;
            position: relative;
        }

        .cake-emoji {
            font-size: 5rem;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        /* Countdown */
        .countdown-title {
            font-size: 1.2rem;
            margin-top: 20px;
            font-weight: 600;
        }

        .countdown {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin: 15px 0 30px 0;
        }

        .time-box {
            background: rgba(255, 255, 255, 0.4);
            padding: 10px 15px;
            border-radius: 10px;
            font-weight: bold;
            min-width: 70px;
        }

        /* Heartfelt Message */
        .wishes {
            font-family: 'Dancing Script', cursive;
            font-size: 2rem;
            line-height: 1.6;
            margin: 30px 0;
            color: #4a4a4a;
            padding: 0 20px;
        }

        /* Wish Button */
        .wish-btn {
            background: linear-gradient(135deg, #ffb7b2, #ffdab9);
            border: none;
            padding: 15px 35px;
            font-size: 1.1rem;
            font-weight: 600;
            color: #4a4a4a;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: 0.3s;
            outline: none;
        }

        .wish-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        }

        /* Sparkles & Floating Elements */
        .sparkle, .balloon, .petal {
            position: absolute;
            pointer-events: none;
            z-index: 1;
        }

        @keyframes floatUp {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }

        /* Footer */
        footer {
            margin-top: 50px;
            padding: 20px;
            font-size: 1rem;
            color: #5d5d5d;
            text-shadow: 0 0 10px rgba(255,255,255,0.5);
            font-weight: 600;
        }

        /* Responsive */
        @media (max-width: 600px) {
            h1 { font-size: 2.5rem; }
            .typing-text { font-size: 1.1rem; }
            .wishes { font-size: 1.6rem; }
            .container { margin: 20px 10px; padding: 20px 10px; }
        }
    </style>
</head>
<body>

    <!-- Fairy Lights -->
    <ul class="fairy-lights">
        <li></li><li></li><li></li><li></li><li></li><li></li><li></li><li></li><li></li><li></li>
    </ul>

    <div class="container">
        <!-- Main Heading -->
        <h1>🎉 Happy Birthday Abubakar! 🎂</h1>
        <p class="typing-text">Wishing you a day full of love and laughter! ✨</p>

        <!-- Bubu Dudu Cutouts (Code-based SVGs - No Image Files Required) -->
        <div class="bubu-dudu-box">
            <!-- Bubu -->
            <svg class="panda-art" viewBox="0 0 100 100">
                <circle cx="50" cy="55" r="35" fill="#fff" stroke="#4a4a4a" stroke-width="3"/>
                <circle cx="25" cy="25" r="12" fill="#4a4a4a"/>
                <circle cx="75" cy="25" r="12" fill="#4a4a4a"/>
                <circle cx="38" cy="48" r="5" fill="#4a4a4a"/>
                <circle cx="62" cy="48" r="5" fill="#4a4a4a"/>
                <ellipse cx="50" cy="58" rx="5" ry="3" fill="#4a4a4a"/>
                <circle cx="28" cy="58" r="6" fill="#ffb7b2" opacity="0.6"/>
                <circle cx="72" cy="58" r="6" fill="#ffb7b2" opacity="0.6"/>
            </svg>
            <!-- Dudu -->
            <svg class="panda-art" viewBox="0 0 100 100" style="animation-delay: 0.5s;">
                <circle cx="50" cy="55" r="35" fill="#fcd7de" stroke="#4a4a4a" stroke-width="3"/>
                <circle cx="25" cy="25" r="12" fill="#4a4a4a"/>
                <circle cx="75" cy="25" r="12" fill="#4a4a4a"/>
                <circle cx="38" cy="48" r="5" fill="#4a4a4a"/>
                <circle cx="62" cy="48" r="5" fill="#4a4a4a"/>
                <ellipse cx="50" cy="58" rx="4" ry="2" fill="#4a4a4a"/>
                <circle cx="28" cy="58" r="5" fill="#ff9aa2" opacity="0.7"/>
                <circle cx="72" cy="58" r="5" fill="#ff9aa2" opacity="0.7"/>
            </svg>
        </div>

        <!-- Birthday Cake Section -->
        <div class="cake-container">
            <div class="cake-emoji">🎂</div>
        </div>

        <!-- Countdown Timer -->
        <p class="countdown-title">💝 Countdown to the Big Day (7 October) 💝</p>
        <div class="countdown" id="countdown">
            <div class="time-box"><span id="days">00</span><br>Days</div>
            <div class="time-box"><span id="hours">00</span><br>Hours</div>
            <div class="time-box"><span id="mins">00</span><br>Mins</div>
            <div class="time-box"><span id="secs">00</span><br>Secs</div>
        </div>

        <!-- Heartfelt Message -->
        <p class="wishes">
            "May your life be filled with happiness, success, love, and unforgettable memories. Wishing you the happiest birthday ever! ❤️"
        </p>

        <!-- Interactive Button -->
        <button class="wish-btn" onclick="makeWish(event)">✨ Make a Wish ✨</button>
    </div>

    <!-- Glowing Footer -->
    <footer>Made with ❤️ especially for Abubakar</footer>

    <script>
        // Automatic Falling Elements (Balloons, Petals, Hearts)
        function createFloatingElement(emoji, className) {
            const el = document.createElement('div');
            el.className = className;
            el.innerText = emoji;
            el.style.left = Math.random() * 100 + 'vw';
            el.style.fontSize = Math.random() * 20 + 20 + 'px';
            el.style.animation = `floatUp ${Math.random() * 4 + 4}s linear forwards`;
            document.body.appendChild(el);
            
            setTimeout(() => { el.remove(); }, 8000);
        }

        setInterval(() => createFloatingElement('🎈', 'balloon'), 600);
        setInterval(() => createFloatingElement('🌸', 'petal'), 800);
        setInterval(() => createFloatingElement('❤️', 'petal'), 1000);
        setInterval(() => createFloatingElement('⭐', 'petal'), 1200);

        // Make a Wish Sparkles Effect
        function makeWish(e) {
            for (let i = 0; i < 30; i++) {
                const sparkle = document.createElement('div');
                sparkle.className = 'sparkle';
                sparkle.innerText = ['✨', '💖', '🎉', '🌟'][Math.floor(Math.random() * 4)];
                sparkle.style.left = e.clientX + (Math.random() * 200 - 100) + 'px';
                sparkle.style.top = e.clientY + (Math.random() * 200 - 100) + 'px';
                sparkle.style.fontSize = '24px';
                sparkle.style.transition = 'all 1s ease-out';
                sparkle.style.position = 'fixed';
                document.body.appendChild(sparkle);

                setTimeout(() => {
                    sparkle.style.transform = 'translateY(-100px) scale(0)';
                    sparkle.style.opacity = '0';
                }, 50);

                setTimeout(() => { sparkle.remove(); }, 1000);
            }
            alert("✨ Your magical wish for Abubakar has been sent to the stars! 🌟");
        }

        // Countdown to actual birthday: 7 October
        function getNextBirthday() {
            const now = new Date();
            let birthDate = new Date(now.getFullYear(), 9, 7); // 9 stands for October (0-indexed in JS)

            if (now > birthDate) {
                birthDate.setFullYear(now.getFullYear() + 1);
            }
            return birthDate.getTime();
        }

        const targetDate = getNextBirthday();

        function updateCountdown() {
            const now = new Date().getTime();
            const difference = targetDate - now;

            const days = Math.floor(difference / (1000 * 60 * 60 * 24));
            const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((difference % (1000 * 60)) / 1000);

            document.getElementById('days').innerText = days < 10 ? '0' + days : days;
            document.getElementById('hours').innerText = hours < 10 ? '0' + hours : hours;
            document.getElementById('mins').innerText = minutes < 10 ? '0' + minutes : minutes;
            document.getElementById('secs').innerText = seconds < 10 ? '0' + seconds : seconds;
        }
        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>
</body>
  </html>
  
