<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Hassan! 💙</title>
    <style>
        * { box-sizing: border-box; }
        body {
            background: linear-gradient(135deg, #0a192f, #172a45);
            color: #f1f5f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            text-align: center;
            margin: 0; padding: 0;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; overflow: hidden;
            position: relative;
        }

        /* Floating Balloons & Bows Background */
        .decorations-container {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            overflow: hidden;
            z-index: 1; pointer-events: none;
        }
        .balloon {
            position: absolute;
            bottom: -100px;
            width: 45px; height: 55px;
            background: #38bdf8;
            border-radius: 50%;
            opacity: 0.6;
            animation: floatUp 7s linear infinite;
        }
        .bow {
            position: absolute;
            bottom: -50px;
            font-size: 24px;
            animation: floatUp 9s ease-in infinite;
            opacity: 0.7;
        }

        @keyframes floatUp {
            0% { transform: translateY(0) scale(0.8); opacity: 0; }
            10% { opacity: 0.8; }
            100% { transform: translateY(-120vh) scale(1); opacity: 0; }
        }

        /* Main Card */
        .card {
            background: rgba(23, 42, 69, 0.8);
            border: 2px solid #0ea5e9;
            backdrop-filter: blur(12px);
            padding: 40px 30px;
            border-radius: 25px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 20px rgba(14, 165, 233, 0.2);
            max-width: 420px; width: 90%;
            z-index: 2; position: relative;
        }

        h1 {
            color: #38bdf8;
            font-size: 2.4rem;
            margin: 15px 0 5px 0;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(56, 189, 248, 0.5);
        }
        
        .bow-title {
            font-size: 2rem;
            color: #38bdf8;
            margin-bottom: 10px;
        }

        p {
            font-size: 1.1rem;
            line-height: 1.6;
            color: #cbd5e1;
            margin: 20px 0;
        }

        /* Interactive Cake & Candle Setup */
        .cake-area {
            position: relative;
            width: 100px; height: 100px;
            margin: 20px auto;
            font-size: 5rem;
            line-height: 1;
        }
        .candle-flame {
            position: absolute;
            top: -25px; left: 50%;
            transform: translateX(-50%);
            font-size: 1.8rem;
            animation: flicker 0.6s infinite alternate;
        }
        @keyframes flicker {
            0% { transform: translateX(-50%) scale(1); opacity: 0.9; }
            100% { transform: translateX(-50%) scale(1.15); opacity: 1; filter: drop-shadow(0 0 8px #f59e0b); }
        }

        .btn {
            background: linear-gradient(135deg, #0ea5e9, #0284c7);
            color: white;
            border: none; padding: 15px 30px;
            font-size: 1.1rem; font-weight: bold;
            border-radius: 30px; cursor: pointer;
            transition: 0.3s; width: 100%;
            box-shadow: 0 4px 15px rgba(14, 165, 233, 0.4);
            margin-top: 10px;
        }
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(14, 165, 233, 0.6);
        }
        
        .audio-status {
            font-size: 0.85rem;
            color: #64748b;
            margin-top: 8px;
        }
    </style>
</head>
<body>

    <div class="decorations-container" id="decorationsContainer"></div>

    <div class="card">
        <div class="bow-title">🎀</div>
        
        <!-- Cake with Animated Candle Flame -->
        <div class="cake-area">
            <div class="candle-flame" id="flame">🔥</div>
            <div class="cake-emoji">🎂</div>
        </div>

        <h1>Hassan!</h1>
        <p>Wishing you an incredible birthday filled with success, heavy vibes, and premium happiness. Blow the candle to play your song! 💙⚡</p>
        
        <button class="btn" onclick="blowCandle()">Blow Candle & Play Song 🕯️💨</button>
        <div class="audio-status">(Make sure your phone volume is UP!)</div>
    </div>

    <!-- Happy Birthday Hassan Song (Custom YouTube/Audio stream fallback track) -->
    <audio id="birthdaySong" src="https://assets.mixkit.co/active_storage/sfx/2042/2042-84.wav" loop></audio>
    <!-- backup song element just in case -->
    <audio id="backupSong" src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" loop></audio>

    <script>
        // Generate Floating Blue Balloons & Bows
        const container = document.getElementById('decorationsContainer');
        const blueColors = ['#0ea5e9', '#38bdf8', '#7dd3fc', '#0284c7', '#bae6fd'];
        
        // Balloons
        for (let i = 0; i < 15; i++) {
            let balloon = document.createElement('div');
            balloon.classList.add('balloon');
            balloon.style.left = Math.random() * 100 + '%';
            balloon.style.animationDelay = Math.random() * 6 + 's';
            balloon.style.backgroundColor = blueColors[Math.floor(Math.random() * blueColors.length)];
            container.appendChild(balloon);
        }

        // Bows
        for (let i = 0; i < 10; i++) {
            let bow = document.createElement('div');
            bow.classList.add('bow');
            bow.innerHTML = '🎀';
            bow.style.left = Math.random() * 100 + '%';
            bow.style.animationDelay = Math.random() * 7 + 's';
            bow.style.fontSize = (Math.random() * 10 + 20) + 'px';
            container.appendChild(bow);
        }

        function blowCandle() {
            // Extinguish flame animation
            const flame = document.getElementById('flame');
            flame.style.display = 'none';

            // Play Birthday Song
            const song = document.getElementById('birthdaySong');
            const backup = document.getElementById('backupSong');
            
            song.play().catch(function() {
                // if first one fails, play backup instrumental right away
                backup.play().catch(e => console.log("Audio play blocked."));
            });

            alert("🎈 💨 You blew the candle!\n\n🎉 Happy Birthday Hassan! May this year bring you endless wins, legendary moments, and pure joy! 👑💙");
        }
    </script>
</body>
</html>
